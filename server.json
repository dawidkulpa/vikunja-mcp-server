{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.dawidkulpa/vikunja-mcp-server",
  "description": "Model Context Protocol server for Vikunja task management",
  "status": "active",
  "repository": {
    "url": "https://github.com/dawidkulpa/vikunja-mcp-server",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registry_type": "npm",
      "registry_base_url": "https://registry.npmjs.org",
      "identifier": "vikunja-mcp-server",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environment_variables": [
        {
          "description": "Vikunja API URL (e.g. https://vikunja.example.com/api/v1)",
          "is_required": true,
          "format": "string",
          "is_secret": false,
          "name": "VIKUNJA_URL"
        },
        {
          "description": "Vikunja API token (starts with tk_) or JWT token",
          "is_required": true,
          "format": "string",
          "is_secret": true,
          "name": "VIKUNJA_API_TOKEN"
        }
      ]
    }
  ]
}
